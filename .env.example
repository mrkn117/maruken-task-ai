# ===================================================
# 空き時間タスク指示AI - 環境変数設定ファイル
# このファイルを .env.local にコピーして値を入力してください
# ===================================================

# Claude API キー（Anthropic API plan 組織で取得）
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Google連携（いずれか1つを設定する）────────────────────────────────────────

# 【推奨・簡単】GAS Web App URL
# gas_script.js をGoogleシートのApps Scriptに貼り付けてデプロイしたURL
# README.md の「GAS設定手順」を参照
GOOGLE_GAS_URL=https://script.google.com/macros/s/xxxxxxx/exec

# 【上級・本番向け】Google サービスアカウント直接接続
# GAS_URLが空の場合にのみ使用される
GOOGLE_SPREADSHEET_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}

# ─── モード設定 ─────────────────────────────────────────────────────────────────
# true  = Googleシートなし・AIモック応答でフル動作確認できる（初期設定）
# false = 本番モード（上記のGoogle設定が必要）
MOCK_MODE=true
